# ============================================================
# AI Tools Docker — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── API Keys (consumed by all tools) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...

# ── OpenClaw ────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=changeme-change-me-0123456789
OPENCLAW_ALLOWED_ORIGINS=["http://localhost"]

# ── Hermes Dashboard ────────────────────────────────────────
HERMES_DASHBOARD_USERNAME=admin
HERMES_DASHBOARD_PASSWORD=changeme

# ── ttyd Terminal ───────────────────────────────────────────
TTYD_USERNAME=admin
TTYD_PASSWORD=changeme

# ── Git identity ────────────────────────────────────────────
GIT_AUTHOR_NAME=AI Tools User
GIT_AUTHOR_EMAIL=ai@tools.local

# ── Host UID/GID (for file ownership) ───────────────────────
UID=1000
GID=1000

# ── Networking ──────────────────────────────────────────────
NGINX_HTTP_PORT=80
TZ=Asia/Shanghai
